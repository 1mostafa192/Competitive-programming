#define fastcode   ios::sync_with_stdio(false);cin.tie(nullptr);
#define all(x) x.begin(),x.end()
using ll = long long;
vector<vector<int>>adj;
vector<bool>vis;
bool flag =0;
void dfs(int u,int comp) {
 vis[u]=1;
 for (auto it:adj[u]) {
  if (it==comp) continue;
  if (!vis[it]) dfs(it,u);
  else flag=1;
 }
}
void solve () {
 int n,m;cin>>n>>m;
 adj.assign(n+1,{});
 vis.assign(n+1,0);
 for (int i=1;i<=m;i++) {
  int u,v;cin>>u>>v;
  adj[u].push_back(v);
  adj[v].push_back(u);
 }
 dfs(1,1);
 cout<<(flag?"YES":"NO")<<endl;
}

signed main() {
 solve();




















